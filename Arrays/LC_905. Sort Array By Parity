class Solution {
    public int[] sortArrayByParity(int[] nums) {
        int i=0;
        int k=nums.length-1;
        while(i<k){
            if((nums[i] & 1) ==1){
                int temp=nums[i];
                nums[i]=nums[k];
                nums[k]=temp;
                k--;
            }
            else{
                i++;
            }
        }
        return nums;
    }
}
