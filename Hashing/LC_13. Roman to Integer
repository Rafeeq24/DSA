import java.util.*;
class Solution {
    public int romanToInt(String s) {
        HashMap<Character,Integer> map=new HashMap<>();
        map.put('I',1);
        map.put('V',5);
        map.put('X',10);
        map.put('L',50);
        map.put('C',100);
        map.put('D',500);
        map.put('M',1000);
        int p=0;
        int l=s.length();
        for(int i=0;i<s.length();i++){
            char ch=s.charAt(i);
            if(ch=='I' && i<l-1 && s.charAt(i+1)=='V'){
                p=p+4;
                i++;
                continue;
            }
            if(ch=='I' && i<l-1 && s.charAt(i+1)=='X'){
                p=p+9;
                i++;
                continue;
            }
              if(ch=='X' && i<l-1 &&  s.charAt(i+1)=='L'){
                p=p+40;
                i++;
                continue;
            }
              if(ch=='X' && i<l-1 && s.charAt(i+1)=='C'){
                p=p+90;
                i++;
                continue;
            }
              if(ch=='C' && i<l-1 && s.charAt(i+1)=='D'){
                p=p+400;
                i++;
                continue;
            }
              if(ch=='C' &&  i<l-1 && s.charAt(i+1)=='M'){
                p=p+900;
                i++;
                continue;
            }


            p=p+ map.get(ch);
        }
        return p;
        
    }
}
